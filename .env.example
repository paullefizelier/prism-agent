# Gemini API key — get one at https://aistudio.google.com/apikey
NUXT_GOOGLE_API_KEY=

# Gemini model id. Swap freely without code changes.
NUXT_AI_MODEL=gemini-3.5-flash

# WooCommerce REST API (WooCommerce > Settings > Advanced > REST API)
NUXT_WOO_URL=https://www.prism-surfboards.com
NUXT_WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NUXT_WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — names expected by @nuxtjs/supabase (NOT the NUXT_PUBLIC_* prefix).
# Settings > API. SECRET key is server-only (service role) and bypasses RLS.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...            # publishable / anon key
SUPABASE_SECRET_KEY=eyJ...     # service role / secret key (server-only)

# Catalog sync auth: Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`.
# Set the same value in Vercel project env so cron requests are authorized.
CRON_SECRET=change-me-to-a-long-random-string

# Admin dashboard: comma-separated emails allowed to access /admin.
# Create these users in Supabase > Authentication > Users (email + password).
NUXT_ADMIN_EMAILS=paul.lefizelier@actualgroup.com
